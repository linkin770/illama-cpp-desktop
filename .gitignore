# dependencies — keep folder, ignore contents
node_modules/*
!node_modules/.gitkeep

# build output — ignored, not uploaded with project
dist/

# local runtime state
desktop-state.json
*.log
logs/

# llama.cpp — keep folder, ignore contents
llama/*
!llama/.gitkeep

# model files
models/
*.gguf
*.ggml
*.bin
*.safetensors
*.pt
*.pth
*.onnx

# ccx — not related to project
ccx/
*.ccx

# fonts — embedded fonts not uploaded
renderer/assets/fonts/
*.zip

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
