  "license": "MIT",
  "type": "module",
  "main": "desktop/main.mjs",
  "productName": "illama Desktop",
  "keywords": [
    "llama.cpp",
    "AI",
    "LLM",
    "local AI",
    "desktop app",
    "Windows",
    "Electron"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/linkin770/illama-cpp-desktop.git"
  },
  "scripts": {
    "start": "npm run build && electron .",
